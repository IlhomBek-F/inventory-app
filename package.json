{
  "name": "inventory-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check-types": "pnpm -r check-types",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "db:push": "pnpm --filter @inventory-app/db db:push",
    "db:studio": "pnpm --filter @inventory-app/db db:studio",
    "db:generate": "pnpm --filter @inventory-app/db db:generate",
    "db:migrate": "pnpm --filter @inventory-app/db db:migrate",
    "db:start": "pnpm --filter @inventory-app/db db:start",
    "db:watch": "pnpm --filter @inventory-app/db db:watch",
    "db:stop": "pnpm --filter @inventory-app/db db:stop",
    "db:down": "pnpm --filter @inventory-app/db db:down"
  },
  "dependencies": {
    "@inventory-app/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@inventory-app/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.28.2"
}
